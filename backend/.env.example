# App
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=false

# Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/jira_ai_assistant

# Encryption key for credentials (32-byte base64 URL-safe)
ENCRYPTION_KEY=your-32-byte-fernet-key-here

# Email (optional — needed for approval workflows)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_EMAIL=admin@yourcompany.com

# Frontend URL (for CORS + approval email links)
FRONTEND_URL=https://your-frontend.onrender.com

# Optional: fallback OpenAI key (users set their own in Settings)
OPENAI_API_KEY=
